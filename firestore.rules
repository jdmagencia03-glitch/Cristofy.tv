rules_version = '2';
// Implante com: firebase deploy --only firestore:rules
// Console alternativo: Firebase → Firestore Database → Regras

service cloud.firestore {
  match /databases/{database}/documents {
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    // Perfis: cada usuário lê e altera apenas os próprios perfis.
    match /users/{userId}/profiles/{profileId} {
      allow read, create, update, delete: if isOwner(userId);
    }

    // Dados do perfil usados na experiência do player/lista.
    match /users/{userId}/profiles/{profileId}/my_list/{itemId} {
      allow read, create, update, delete: if isOwner(userId);
    }

    match /users/{userId}/profiles/{profileId}/watch_history/{historyId} {
      allow read, create, update, delete: if isOwner(userId);
    }

    // Assinaturas: leitura pelo próprio usuário; escrita apenas via backend (Admin SDK).
    match /subscriptions/{subscriptionId} {
      allow read: if isSignedIn() &&
        (
          resource.data.user_uid == request.auth.uid ||
          resource.data.user_email == request.auth.token.email
        );
      allow create, update, delete: if false;
    }

    // Catálogo público.
    match /series/{seriesId} {
      allow read: if true;
      allow write: if isSignedIn();
    }

    match /episodes/{episodeId} {
      allow read: if true;
      allow write: if isSignedIn();
    }

    match /featured_banners/{bannerId} {
      allow read: if true;
      allow write: if isSignedIn();
    }
  }
}
