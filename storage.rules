rules_version = '2';
// Implante com: firebase deploy --only storage
// Console alternativo: Firebase → Storage → Regras

service firebase.storage {
  match /b/{bucket}/o {
    // Imagens do site: leitura pública (URLs em capas/banners no app)
    // Escrita só na pasta do próprio usuário autenticado
    match /site-media/{userId}/{allPaths=**} {
      allow read: if true;
      allow write: if request.auth != null && request.auth.uid == userId;
    }
  }
}
