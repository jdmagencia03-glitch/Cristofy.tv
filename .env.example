# E-mails separados por vírgula = acesso ao menu Admin (Firebase Auth)
VITE_ADMIN_EMAILS=

# Catálogo (séries/episódios/banners): omita ou true = Firestore quando Firebase estiver ok.
# false = usar só Base44 (defina também VITE_BASE44_APP_ID)
VITE_USE_FIRESTORE_CATALOG=

# Projeto Base44 (admin legado: usuários, códigos, métricas, integrações Core.UploadFile / InvokeLLM)
VITE_BASE44_APP_ID=
VITE_BASE44_FUNCTIONS_VERSION=
VITE_BASE44_APP_BASE_URL=
