VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=
VITE_FIREBASE_MEASUREMENT_ID=

# E-mails separados por vírgula = acesso ao menu Admin (Firebase Auth)
VITE_ADMIN_EMAILS=

# Catálogo (séries/episódios/banners): omita ou true = Firestore quando Firebase estiver ok.
# false = usar só Base44 (defina também VITE_BASE44_APP_ID)
VITE_USE_FIRESTORE_CATALOG=

# Projeto Base44 (admin legado: usuários, códigos, métricas, integrações Core.UploadFile / InvokeLLM)
VITE_BASE44_APP_ID=
VITE_BASE44_FUNCTIONS_VERSION=
VITE_BASE44_APP_BASE_URL=

# Assinaturas (Firebase Functions + Asaas)
# Ex.: https://southamerica-east1-SEU_PROJETO.cloudfunctions.net
VITE_FIREBASE_FUNCTIONS_BASE_URL=
# true = fallback para Base44 se Firebase Functions falhar; false = Firebase only
VITE_SUBSCRIPTION_BASE44_FALLBACK=true
